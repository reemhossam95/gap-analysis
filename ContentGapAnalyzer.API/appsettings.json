{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  "YouTube": {
    "ApiKey": "",
    "BaseUrl": "https://www.googleapis.com/youtube/v3/",
    "MaxResults": 25
  },

  "Gemini": {
    "ApiKeys": [],
    "Model": "gemini-2.5-flash",
    "BaseUrl": "https://generativelanguage.googleapis.com/v1beta/"
  },

  "AllowedOrigins": [
    "http://localhost:3000",
    "http://localhost:5173",
    "https://auto-tube-eight.vercel.app"
  ],

  "Caching": {
    "TrendingExpirationMinutes": 30,
    "GapReportExpirationMinutes": 60
  },

  "RateLimiting": {
    "PermitLimit": 100,
    "WindowMinutes": 1,
    "QueueLimit": 10
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },

  "AllowedHosts": "*"
}